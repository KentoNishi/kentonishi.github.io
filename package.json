{
	"name": "kentonishi.github.io",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": "^20.19 || ^22.12 || >=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --no-tsconfig --ignore \"node_modules,.svelte-kit,build\"",
		"check:watch": "svelte-kit sync && svelte-check --no-tsconfig --ignore \"node_modules,.svelte-kit,build\" --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^22.19.19",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"exio": "^0.6.54"
	}
}
